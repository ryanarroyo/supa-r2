# Copy to .env and fill in. NEVER commit .env.
#
# With NONE of these set, r2db runs against a local directory (R2DB_DIR, default
# ./.r2db) so you can develop and test with no cloud account. Set the R2_* vars
# to talk to a real Cloudflare R2 bucket.

# --- Cloudflare R2 -----------------------------------------------------------
# Create an R2 API token with Object Read & Write for the bucket:
#   Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# The bucket the document store and publisher use by default.
R2_BUCKET=my-app-db

# --- Optional: a separate PRIVATE bucket for file backups --------------------
# `r2db backup/restore` and state.backup_file() prefer this bucket. Keep it
# separate from any PUBLIC serving bucket. NEVER back up private data to a
# public bucket.
# R2_STATE_BUCKET=my-app-state

# --- Optional: local filesystem target root ---------------------------------
# Where FilesystemTarget writes when R2 creds are absent.
# R2DB_DIR=.r2db
